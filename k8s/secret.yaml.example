# TEMPLATE — copy this file to secret.yaml and fill in real values, exactly
# like backend/.env.example -> backend/.env. `secret.yaml` (no `.example`)
# is git-ignored (see root .gitignore) specifically so this can never be
# accidentally committed with real credentials.
#
#   cp k8s/secret.yaml.example k8s/secret.yaml
#   # then edit k8s/secret.yaml with real values before applying it
#
# Using stringData (not the base64-encoded `data` field) so values here are
# plain text, same ergonomics as a .env file — Kubernetes base64-encodes
# them itself once applied.
apiVersion: v1
kind: Secret
metadata:
  name: skillstreak-secret
  namespace: skillstreak
type: Opaque
stringData:
  POSTGRES_PASSWORD: CHANGE_ME
  # Signs/verifies the bearer sessionToken issued at POST /players. Must be
  # a real, random secret from a secrets manager for anything beyond a
  # throwaway test cluster — never reuse the dev-only placeholder from
  # backend/.env.example.
  JWT_SECRET: CHANGE_ME
  SMTP_USER: CHANGE_ME
  SMTP_PASSWORD: CHANGE_ME
  # Fas 3 (docs/adr/0010-video-storage-and-serving.md) — MinIO's root
  # credentials. This dev/beta setup uses the single root key pair as the
  # API's own MinIO credentials too (same posture as this file already
  # takes with POSTGRES_PASSWORD) — a real production hardening pass should
  # mint a narrower, bucket-scoped key instead of using root credentials
  # (Fas 4 territory, tracked the same way JWT_SECRET's rotation is).
  MINIO_ROOT_USER: CHANGE_ME
  MINIO_ROOT_PASSWORD: CHANGE_ME
