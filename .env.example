# Copy this file to .env and adjust as needed. .env is git-ignored — never
# commit real credentials. These are dev-only defaults; Fas 4's
# production-hardening pass (secrets management, etc.) is out of scope here.

# --- Postgres --------------------------------------------------------------
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app_dev
# Host-side port mapping (container always listens on 5432 internally).
POSTGRES_PORT=5432

# --- Redis -------------------------------------------------------------------
# Host-side port mapping (container always listens on 6379 internally).
REDIS_PORT=6379

# --- API ---------------------------------------------------------------------
NODE_ENV=development
# Host-side port mapping (container always listens on 3000 internally).
API_PORT=3000
# Signs/verifies the bearer sessionToken issued at POST /players. Dev-only
# placeholder — a real deploy needs a proper secret from a secrets manager.
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=180d
