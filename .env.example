# Copy this file to .env and adjust as needed. .env is git-ignored — never
# commit real credentials. These are dev-only defaults; Fas 4's
# production-hardening pass (secrets management, etc.) is out of scope here.

# --- Postgres --------------------------------------------------------------
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app_dev
# Host-side port mapping (container always listens on 5432 internally).
POSTGRES_PORT=5432

# --- Redis -------------------------------------------------------------------
# Host-side port mapping (container always listens on 6379 internally).
REDIS_PORT=6379

# --- API ---------------------------------------------------------------------
NODE_ENV=development
# Host-side port mapping (container always listens on 3000 internally).
API_PORT=3000
# Signs/verifies the bearer sessionToken issued at POST /players. Dev-only
# placeholder — a real deploy needs a proper secret from a secrets manager.
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=180d

# --- Email (SMTP) -------------------------------------------------------------
# Sends the parental-consent request email (docs/adr/0002-data-model.md
# addendum §2). Configured here for Google Workspace's SMTP relay
# (smtp-relay.gmail.com) — see
# https://support.google.com/a/answer/2956491 for the Workspace-side setup
# this requires (allowed senders / IP allowlist, since the relay trusts your
# Workspace domain rather than a per-app password in most configs).
# SMTP_PASSWORD is intentionally left blank here — fill it in on your local
# .env only, never here. If your relay config doesn't need a password (IP
# allowlist), you can leave it blank in .env too.
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.example
SMTP_PASSWORD=
SMTP_FROM=SkillStreak <noreply@yourdomain.example>
# The address a parent's browser can reach to click the consent link —
# localhost only works for you; testing from a phone needs your LAN IP
# (e.g. http://192.168.1.23:3000), a real domain once one exists.
APP_PUBLIC_URL=http://localhost:3000
# Mail sending is a no-op with a clear log line (not an app-boot failure)
# until SMTP_HOST is set — see backend/src/mail/mail.service.ts.

# --- Video clips / MinIO (Fas 3) -----------------------------------------------
# Self-hosted S3-API object store for video clips
# (docs/adr/0010-video-storage-and-serving.md). Unlike SMTP, this is a
# required dependency (like Postgres/Redis), not an optional-degrade one —
# see backend/src/config/env.validation.ts.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=clips
# Host-side port mappings (container always listens on 9000/9001 internally).
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Tunable product config (ADR-0010 Decision 5) — recommended defaults, not
# architecturally fixed.
CLIP_RETENTION_DAYS=90
CLIP_PENDING_UPLOAD_TTL_MINUTES=60
