# Local (non-Docker) dev only, e.g. `npm run start:dev` against containers
# started with `docker-compose up postgres redis`. When running the api
# service itself via docker-compose, these are supplied by the root
# .env file / docker-compose.yml instead — see ../.env.example.

PORT=3000

# Must match the Postgres credentials the postgres container was started
# with (see ../.env.example) if connecting from the host.
DATABASE_URL=postgres://app:app@localhost:5432/app_dev

REDIS_URL=redis://localhost:6379

# Signs/verifies the bearer sessionToken issued at POST /players (a JWT
# scoped to a single playerId, no login step — see
# docs/api/phase1-contract.md). Dev-only placeholder secret; a real deploy
# needs a proper secret from a secrets manager (Fas 4 hardening).
JWT_SECRET=dev-only-change-me
# Optional — defaults to 180d (see AuthModule) if unset. Token
# expiry/refresh/reissue-if-lost is a backend-developer implementation
# detail per the contract, not fixed by it.
JWT_EXPIRES_IN=180d

# --- Email (SMTP) -------------------------------------------------------------
# Sends the parental-consent request email. Google Workspace SMTP relay —
# see ../.env.example for the fuller comment. Leave SMTP_PASSWORD blank
# here; fill it in only in your own untracked .env.
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.example
SMTP_PASSWORD=
SMTP_FROM=SkillStreak <noreply@yourdomain.example>
APP_PUBLIC_URL=http://localhost:3000

# --- Video clips / MinIO (Fas 3) -----------------------------------------------
# Requires `docker-compose up minio` (or the full stack) running locally —
# see docs/adr/0010-video-storage-and-serving.md. Required, not optional
# (see env.validation.ts) — unlike SMTP, there's no clean no-op degrade for
# a feature that's fundamentally "store/serve video bytes."
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=clips
CLIP_RETENTION_DAYS=90
CLIP_PENDING_UPLOAD_TTL_MINUTES=60
