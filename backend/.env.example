# Local (non-Docker) dev only, e.g. `npm run start:dev` against containers
# started with `docker-compose up postgres redis`. When running the api
# service itself via docker-compose, these are supplied by the root
# .env file / docker-compose.yml instead — see ../.env.example.

PORT=3000

# Must match the Postgres credentials the postgres container was started
# with (see ../.env.example) if connecting from the host.
DATABASE_URL=postgres://app:app@localhost:5432/app_dev

REDIS_URL=redis://localhost:6379
